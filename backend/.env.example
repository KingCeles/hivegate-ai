# Required in production
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/beecount
ADMIN_EMAIL=owner@example.com
CORS_ORIGINS=https://your-frontend.vercel.app

# Model paths, relative to backend/
ID_MODEL=id_model.pt
COUNT_MODEL=bee_motion.pt
YOLO_DEVICE=cpu

# AI helper provider. Use Groq compound models for higher TPM on this app.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=groq/compound-mini

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
