# Copy to .env.local for local development
# Leave blank — Vite proxy handles /api -> localhost:5000
VITE_API_URL=

# For production on Vercel, set this to your Railway backend URL:
# VITE_API_URL=https://your-backend.railway.app

# Separate motion/counting backend. Leave blank locally when using the Vite proxy.
VITE_COUNT_API_URL=/motion-api

# For production, set this to the deployed motion backend URL:
# VITE_COUNT_API_URL=https://your-motion-backend.railway.app
